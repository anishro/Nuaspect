rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Check helper for valid document and key sizes to prevent wallet exhaustions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    // 1. Session Settings/Config
    match /config/session {
      allow read: if true;
      allow write, update: if incoming().topic is string 
        && incoming().topic.size() > 0 
        && incoming().topic.size() <= 500
        && incoming().date is string
        && incoming().time is string
        && incoming().price is number
        && incoming().price >= 0;
    }
    
    // 2. Seminar/Session Registrations
    match /registrations/{registrationId} {
      allow read: if true;
      allow create: if incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 200
        && incoming().email is string
        && incoming().email.size() > 0
        && incoming().phone is string
        && incoming().topic is string
        && incoming().price is number
        && incoming().status in ['pending', 'paid'];
      allow update, delete: if true;
    }
    
    // 3. Client Inquiries (Contact Queries)
    match /queries/{queryId} {
      allow read: if true;
      allow create: if incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 200
        && incoming().email is string
        && incoming().email.size() > 0
        && incoming().message is string
        && incoming().message.size() > 0
        && incoming().message.size() <= 5000;
      allow update, delete: if true;
    }
    
    // 4. Therapy Academic Blogs
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if incoming().title is string
        && incoming().title.size() > 0
        && incoming().title.size() <= 500
        && incoming().content is string
        && incoming().content.size() > 0
        && incoming().author is string
        && incoming().author.size() > 0;
      allow update, delete: if true;
    }
  }
}
